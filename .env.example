# Copy to .env and fill in real values — never commit .env
POSTGRES_DB=waver
POSTGRES_USER=waver
POSTGRES_PASSWORD=change_me_before_use

DATABASE_URL=postgresql+asyncpg://waver:change_me_before_use@localhost:5432/waver
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
WAVER_DEFAULT_WORKSPACE=default
WAVER_PRODUCTION_MODE=false
WAVER_API_KEYS_REQUIRED=false
WAVER_DEFAULT_REQUESTS_PER_MINUTE=120
WAVER_DEFAULT_BYTES_PER_MINUTE=5242880
WAVER_MAX_RAW_BYTES=1048576
WAVER_MAX_RAW_SOURCES=20
WAVER_MAX_CONNECTORS=3
WAVER_MAX_TOP_K=50
WAVER_MAX_WINDOWS=5000
WAVER_LATENCY_GATE_P95_MS=200
WAVER_LATENCY_GATE_MAX_BYTES=65536
WAVER_MODEL_DIR=models
WAVER_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
WAVER_MRL_QUERY_PREFIX=Represent this sentence for searching relevant passages: 
WAVER_MRL_DOCUMENT_PREFIX=
WAVER_RETRIEVER=bm25
WAVER_RUST_BM25_MODE=python
WAVER_RUST_RRF=false
WAVER_RUST_RRF_SHADOW=false
WAVER_TINY_MAX_BYTES=2097152
WAVER_MEDIUM_MAX_BYTES=33554432
WAVER_PAYLOAD_CACHE_TTL=300
WAVER_PAYLOAD_CACHE_MAX_ENTRIES=10
WAVER_SESSION_CORPUS_DEFAULT_TTL_SECONDS=86400
WAVER_SESSION_CORPUS_MAX_TTL_SECONDS=604800
MAX_UPLOAD_BYTES=52428800
