# Copy to .env and fill in real values — never commit .env
POSTGRES_DB=waver
POSTGRES_USER=waver
POSTGRES_PASSWORD=change_me_before_use

DATABASE_URL=postgresql+asyncpg://waver:change_me_before_use@localhost:5432/waver
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
WAVER_DEFAULT_WORKSPACE=default
WAVER_MODEL_DIR=backend/models
WAVER_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
WAVER_RETRIEVER=bm25
WAVER_RUST_BM25_MODE=python
WAVER_RUST_RRF=false
WAVER_RUST_RRF_SHADOW=false
WAVER_TINY_MAX_BYTES=2097152
WAVER_MEDIUM_MAX_BYTES=33554432
WAVER_PAYLOAD_CACHE_TTL=300
WAVER_PAYLOAD_CACHE_MAX_ENTRIES=10
MAX_UPLOAD_BYTES=52428800
