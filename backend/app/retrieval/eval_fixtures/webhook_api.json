      "id": "webhook_json_exact_timeout",
      "profiles": ["smoke", "regression", "latency"],
      "query": "status code 503 timeout",
      "top_k": 3,
      "documents": [
        {
          "source_id": "webhook-500",
          "source_name": "webhook-500.json",
          "source_origin": "connector",
          "source_type": "webhook",
          "media_type": "application/json",
          "content": "{\"service\":\"billing-api\",\"status_code\":503,\"error\":\"timeout contacting ledger\"}"
        },
        {
          "source_id": "webhook-ok",
          "source_name": "webhook-ok.json",
          "source_origin": "connector",
          "source_type": "webhook",
          "media_type": "application/json",
          "content": "{\"service\":\"billing-api\",\"status_code\":200,\"error\":null}"
        }
      ],
      "expected": [
        {
          "source_id": "webhook-500",
          "must_include_text": "503",
          "match_type": "exact"
        }
      ]
    },
    {
      "id": "webhook_json_semantic_failure",
